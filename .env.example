# Server
PORT=8088
NODE_ENV=production
LOG_LEVEL=info
DRY_RUN=false

# Square webhook verification. This URL must exactly match the Square webhook subscription URL.
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=https://webhook.thestrawberryshopyork.com/square-webhook.php

# Used to sign the Shopify install state value. Set a long random value in production.
SHOPIFY_OAUTH_STATE_SECRET=

# Existing Strawberry MySQL database
MYSQL_HOST=192.168.12.35
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=Strawberry

# Local table names from the legacy PHP app
SKU_TABLE=SKU_Temp
SKU_HISTORY_TABLE=SKU_History
WEBHOOK_TABLE=square_webhook_events

# Shopify, current store from legacy code
SHOPIFY_STORES=strawberry,nwt
SHOPIFY_STRAWBERRY_NAME=The Strawberry Shop York
SHOPIFY_STRAWBERRY_DOMAIN=tersheholdings.myshopify.com
SHOPIFY_STRAWBERRY_API_VERSION=2026-07
SHOPIFY_STRAWBERRY_ACCESS_METHOD=admin_token
SHOPIFY_STRAWBERRY_ADMIN_ACCESS_TOKEN=
SHOPIFY_STRAWBERRY_CLIENT_ID=
SHOPIFY_STRAWBERRY_CLIENT_SECRET=
SHOPIFY_STRAWBERRY_REDIRECT_URI=https://YOUR_DOMAIN/shopify/oauth/callback
SHOPIFY_STRAWBERRY_SCOPES=read_products,write_inventory
SHOPIFY_STRAWBERRY_EXPIRING_OFFLINE_TOKENS=false
SHOPIFY_STRAWBERRY_LOCATION_ID=gid://shopify/Location/103468007794
SHOPIFY_STRAWBERRY_ENABLED=true
SHOPIFY_STRAWBERRY_USE_LEGACY_SHOPIFY_ID_COLUMN=true

# NewWithTags store. Newer/public apps should connect once through /shopify/install/nwt,
# store the expiring offline token response, and refresh it before background webhook syncs.
SHOPIFY_NWT_NAME=New With Tags
SHOPIFY_NWT_DOMAIN=
SHOPIFY_NWT_API_VERSION=2026-07
SHOPIFY_NWT_ACCESS_METHOD=expiring_offline_token
SHOPIFY_NWT_ADMIN_ACCESS_TOKEN=
SHOPIFY_NWT_REFRESH_TOKEN=
SHOPIFY_NWT_ACCESS_TOKEN_EXPIRES_AT=
SHOPIFY_NWT_REFRESH_TOKEN_EXPIRES_AT=
SHOPIFY_NWT_CLIENT_ID=
SHOPIFY_NWT_CLIENT_SECRET=
SHOPIFY_NWT_REDIRECT_URI=https://YOUR_DOMAIN/shopify/oauth/callback
SHOPIFY_NWT_SCOPES=read_products,write_inventory
SHOPIFY_NWT_EXPIRING_OFFLINE_TOKENS=true
SHOPIFY_NWT_LOCATION_ID=
SHOPIFY_NWT_ENABLED=false
SHOPIFY_NWT_USE_LEGACY_SHOPIFY_ID_COLUMN=false

# Walmart Marketplace Inventory API v3
WALMART_ENABLED=false
WALMART_BASE_URL=https://marketplace.walmartapis.com
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=
WALMART_SHIP_NODE=

# Amazon SP-API Listings Items API v2021-08-01
AMAZON_ENABLED=false
AMAZON_ENDPOINT=https://sellingpartnerapi-na.amazon.com
AMAZON_REGION=us-east-1
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_SELLER_ID=
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_LWA_REFRESH_TOKEN=
AMAZON_AWS_ACCESS_KEY_ID=
AMAZON_AWS_SECRET_ACCESS_KEY=
AMAZON_RANDOMIZE_VENDORS=Inis,TRF,Savannah Bee,Demdaco
